DEEPGRAM_API_KEY=your_deepgram_api_key
OPENAI_API_KEY=your_openai_api_key
CARTESIA_API_KEY=your_cartesia_api_key

# ── Per-agent provider selection ──────────────────────────────────────────────
# Each agent picks its STT / LLM / TTS provider via these keys (set per agent in
# its config, or here as process-wide defaults). Unknown providers, missing keys,
# or init failures log a warning and fall back to the default for that modality.
# See services.py for the full registry of supported providers.

# STT: deepgram (default), assemblyai, gladia, openai, groq
STT_PROVIDER=deepgram
# STT_MODEL=            # provider-specific (e.g. nova-3, gpt-4o-transcribe)
# STT_LANGUAGE=en
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key
# GLADIA_API_KEY=your_gladia_api_key

# LLM: openai (default, also any OpenAI-compatible host via OPENAI_BASE_URL),
#      anthropic, google, groq, openrouter, together, fireworks, deepseek,
#      cerebras, perplexity, ollama
LLM_PROVIDER=openai
# LLM_MODEL=            # e.g. gpt-4o-mini, claude-sonnet-4-6, llama-3.3-70b-versatile
# LLM_BASE_URL=         # override the endpoint (OpenAI-compatible hosts)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1   # legacy alias, still honoured
# OPENAI_MODEL=         # legacy alias for LLM_MODEL, still honoured
# ANTHROPIC_API_KEY=your_anthropic_api_key
# GOOGLE_API_KEY=your_google_api_key
# GROQ_API_KEY=your_groq_api_key

# TTS: deepgram (default), cartesia, elevenlabs, openai
TTS_PROVIDER=deepgram
# TTS_VOICE=            # provider-specific voice id/name (overrides the *_TTS_VOICE below)
# TTS_MODEL=            # provider-specific (e.g. eleven_flash_v2_5)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
CARTESIA_TTS_VOICE=e07c00bc-4134-4eae-9ea4-1a55fb45746b
DEEPGRAM_TTS_VOICE=aura-2-helena-en

# Optional: Connect via Daily WebRTC locally
DAILY_API_KEY=your_daily_api_key

# Postgres — durable store for agent configs/flows/metadata (source of truth).
PG_HOST=84.46.251.98
PG_PORT=5432
PG_USER=faraz
PG_PASSWORD=mypass
PG_DATABASE=faraz
# Retry attempts per DB write before the manager aborts/crashes.
PG_MAX_RETRIES=3